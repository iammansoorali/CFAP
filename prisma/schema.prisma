generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String?
  profile  Profile?
  goals    Goal[]
}

model Profile {
  id      String @id @default(uuid())
  userId  String @unique
  country String?
  user    User @relation(fields: [userId], references: [id])
}

model Goal {
  id      String @id @default(uuid())
  title   String
  userId  String
  user    User @relation(fields: [userId], references: [id])
}

model CarbonEntry {
  id              String @id @default(uuid())
  totalEmissionKg Float
}